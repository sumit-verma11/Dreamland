# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nestiq?schema=public"

# --- NextAuth.js ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- OAuth providers (Google) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Twilio (SMS / OTP). Leave blank to log OTPs to the dev console. ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Unsigned upload preset for client-side uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
